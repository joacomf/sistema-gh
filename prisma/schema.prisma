// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Proveedor {
  id        String   @id @default(uuid())
  nombre    String   @db.VarChar(255)
  notas     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  descuentos DescuentoProveedor[]
  stocks     Stock[]
  facturas   Factura[]
}

model DescuentoProveedor {
  id          String    @id @default(uuid())
  proveedorId String
  descripcion String    @db.VarChar(255)
  porcentaje  Decimal   @db.Decimal(5, 2)
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
}

model Stock {
  id               String    @id @default(uuid())
  proveedorId      String
  codigo           String    @db.VarChar(100)
  codigoOriginal   String?   @db.VarChar(100)
  descripcion      String    @db.VarChar(255)
  cantidad         Int       @default(0)
  cantidadCritica  Int       @default(0)
  cantidadSugerida Int       @default(0)
  fechaPedido      DateTime?
  fechaRecibido    DateTime?
  precioCosto      Decimal   @default(0) @db.Decimal(10, 2)
  precioLista      Decimal   @default(0) @db.Decimal(10, 2)
  precioVenta      Decimal   @default(0) @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  proveedor        Proveedor        @relation(fields: [proveedorId], references: [id])
  repuestosPedido  RepuestoPedido[]
  facturaItems     FacturaItem[]
  ventaItems       VentaItem[]
}

model RepuestoPedido {
  id            String    @id @default(uuid())
  stockId       String
  cantidad      Int
  fechaPedido   DateTime?
  fechaRecibido DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

model Factura {
  id          String   @id @default(uuid())
  proveedorId String
  numero      String   @db.VarChar(100)
  importe     Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proveedor Proveedor   @relation(fields: [proveedorId], references: [id])
  items     FacturaItem[]
}

model FacturaItem {
  id        String   @id @default(uuid())
  facturaId String
  stockId   String
  cantidad  Int
  createdAt DateTime @default(now())

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  stock   Stock   @relation(fields: [stockId], references: [id], onDelete: Restrict)
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  MERCADO_PAGO
}

model Venta {
  id          String     @id @default(uuid())
  descripcion String     @db.VarChar(500)
  importe     Decimal    @db.Decimal(10, 2)
  metodoPago  MetodoPago
  facturada   Boolean    @default(false)
  fecha       DateTime   @default(now())
  createdAt   DateTime   @default(now())

  items VentaItem[]
}

model VentaItem {
  id             String  @id @default(uuid())
  ventaId        String
  stockId        String
  descripcion    String  @db.VarChar(255)
  cantidad       Int
  precioCosto    Decimal @default(0) @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Restrict)
}

model Gasto {
  id          String   @id @default(uuid())
  descripcion String   @db.VarChar(255)
  importe     Decimal  @db.Decimal(10, 2)
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Configuracion {
  clave String @id
  valor String @db.VarChar(500)
}
