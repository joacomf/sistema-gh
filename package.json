{
  "name": "sistema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:up && next dev",
    "build": "next build",
    "start": "npm run db:up && next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:up": "docker compose -f local/docker-compose.yml up -d",
    "db:down": "docker compose -f local/docker-compose.yml down",
    "test:e2e": "docker compose -f local/docker-compose-test.yml up -d && sleep 5 && DATABASE_URL=\"mysql://root:root@localhost:3307/sistema_test\" npx prisma migrate deploy && PLAYWRIGHT_TEST=true DATABASE_URL=\"mysql://root:root@localhost:3307/sistema_test\" npm run build && DATABASE_URL=\"mysql://root:root@localhost:3307/sistema_test\" npx playwright test ; docker compose -f local/docker-compose-test.yml down"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "mysql2": "^3.22.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^6.4.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
