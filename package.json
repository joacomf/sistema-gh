{
  "name": "sistema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:up && next dev",
    "build": "next build",
    "start": "npm run db:up && next start",
    "lint": "eslint",
    "db:up": "docker compose -f local/docker-compose.yml up -d",
    "db:down": "docker compose -f local/docker-compose.yml down",
    "test:e2e": "docker compose -f local/docker-compose-test.yml up -d && sleep 5 && DATABASE_URL=$TEST_DATABASE_URL npx prisma migrate deploy && DATABASE_URL=$TEST_DATABASE_URL npx playwright test && docker compose -f local/docker-compose-test.yml down"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "mysql2": "^3.22.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}